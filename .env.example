# Development default. Replace with a persistent database path or hosted database before deployment.
DATABASE_URL="file:./prisma/dev.db"
# Generate a long random value before deployment.
SESSION_SECRET="replace-with-a-random-secret"
# Optional. Override only if the primary hosted Korean holiday JSON source changes.
HOLIDAY_API_BASE_URL="https://holidays.hyunbin.page"
# Optional. Override only if the public fallback holiday API changes.
HOLIDAY_API_FALLBACK_BASE_URL="https://date.nager.at/api/v3/PublicHolidays"
